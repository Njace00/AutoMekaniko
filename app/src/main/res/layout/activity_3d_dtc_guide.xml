<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0a">

    <!-- TOP BAR — pinned to top, fixed height -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="#232222"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/burger"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_marginStart="16dp"
            android:gravity="center_vertical"
            android:text="☰"
            android:textColor="#e02020"
            android:textSize="24sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:gravity="center_vertical"
            android:text="AutoMekaniko"
            android:textColor="#e02020"
            android:textSize="18sp"
            app:layout_constraintStart_toEndOf="@id/burger"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- BOTTOM BAR — pinned to bottom, fixed height -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="#1a1a1a"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/hometxt"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center"
            android:text="Home"
            android:textColor="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/livetxt"/>

        <TextView
            android:id="@+id/livetxt"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center"
            android:text="Live Data"
            android:textColor="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/hometxt"
            app:layout_constraintEnd_toStartOf="@id/connecttxt"/>

        <TextView
            android:id="@+id/connecttxt"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center"
            android:text="Connect"
            android:textColor="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/livetxt"
            app:layout_constraintEnd_toStartOf="@id/settingtxt"/>

        <TextView
            android:id="@+id/settingtxt"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center"
            android:text="Settings"
            android:textColor="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/connecttxt"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- SLIDE PANEL — fixed 120dp height, sits above bottomBar, same as maintenance -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/slidePanel"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:background="#AA111111"
        android:padding="8dp"
        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="86dp"
            android:layout_height="38dp"
            android:text="Prev"
            android:textAllCaps="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="86dp"
            android:layout_height="38dp"
            android:text="Next"
            android:textAllCaps="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>



        <TextView
            android:id="@+id/slideTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#e02020"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/slideDesc"
            app:layout_constraintStart_toEndOf="@id/btnPrev"
            app:layout_constraintEnd_toStartOf="@id/btnNext"/>

        <TextView
            android:id="@+id/slideDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:maxLines="2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/slideTitle"
            app:layout_constraintEnd_toEndOf="@id/slideTitle"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!--
        SCENE VIEW — now fills the full space between topBar and slidePanel,
        exactly like the maintenance layout. All overlays float on top of it.
    -->
    <io.github.sceneview.SceneView
        android:id="@+id/sceneView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/slidePanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- LOCK OVERLAY — covers sceneView exactly -->
    <View
        android:id="@+id/lockOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="@id/sceneView"
        app:layout_constraintBottom_toBottomOf="@id/sceneView"
        app:layout_constraintStart_toStartOf="@id/sceneView"
        app:layout_constraintEnd_toEndOf="@id/sceneView"/>

    <!--
        DTC SPINNER OVERLAY — floats at the top of the sceneView.
        Anchored to sceneView top, full width with margin.
        Touch passes through to sceneView beneath when not interacting.
    -->
    <Spinner
        android:id="@+id/dtcSpinner"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/spinner_border"
        app:layout_constraintTop_toTopOf="@id/sceneView"
        app:layout_constraintStart_toStartOf="@id/sceneView"
        app:layout_constraintEnd_toEndOf="@id/sceneView"/>

    <!--
        INFO CARD + PARTS SCROLL OVERLAY — floats below the spinner,
        anchored to the right side so the 3D model stays visible on the left.
        Max height capped so it never covers the whole scene.
        visibility="gone" until a DTC code is selected (same as before).
    -->
    <ScrollView
        android:id="@+id/topScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:background="#CC0a0a0a"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/dtcSpinner"
        app:layout_constraintBottom_toTopOf="@id/checklistOverlay"
        app:layout_constraintStart_toStartOf="@id/sceneView"
        app:layout_constraintEnd_toEndOf="@id/sceneView"
        app:layout_constraintHeight_max="260dp"
        app:layout_constraintVertical_bias="0.0">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">


            <TextView
                android:id="@+id/pageTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="DTC Codes"
                android:textColor="#ffffff"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="parent"
                app:layout_constraintBaseline_toBaselineOf="parent"/>

            <TextView
                android:id="@+id/pageSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="10dp"
                android:text="Select a code to view the repair guide"
                android:textColor="#888888"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/pageTitle"/>

            <!-- DTC info card — shown once a code is selected -->
            <androidx.cardview.widget.CardView
                android:id="@+id/infoCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                app:cardBackgroundColor="#1e1e1e"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/pageSub">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvDtcCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#2a0a0a"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:text="P0301"
                        android:textColor="#e02020"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <TextView
                        android:id="@+id/tvDtcName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Cylinder 1 Misfire Detected"
                        android:textColor="#ffffff"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/tvDtcCode"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvDtcCode"/>



                    <View
                        android:id="@+id/divider"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:background="#2e2e2e"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvDtcName"/>

                    <TextView
                        android:id="@+id/tvDtcDesc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingMultiplier="1.4"
                        android:text="A misfire in cylinder 1 means the fuel-air mixture is not igniting correctly."
                        android:textColor="#aaaaaa"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/divider"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Parts section -->
            <LinearLayout
                android:id="@+id/partsSection"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/infoCard">

                <TextView
                    android:id="@+id/partsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Parts you may need"
                    android:textColor="#888888"
                    android:textSize="11sp"/>

                <LinearLayout
                    android:id="@+id/partsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!--
        CHECKLIST OVERLAY — floats bottom-left of sceneView,
        above the slidePanel. Same as maintenance layout.
    -->
    <LinearLayout
        android:id="@+id/checklistOverlay"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:orientation="vertical"
        android:background="#CC111111"
        android:padding="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/slidePanel"
        app:layout_constraintStart_toStartOf="@id/sceneView">

        <TextView
            android:id="@+id/overlayTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#e02020"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:id="@+id/checklistContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>