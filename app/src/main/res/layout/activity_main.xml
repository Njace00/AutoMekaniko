<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0a">

    <!-- TOP BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#232222"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Burger menu -->
        <TextView
            android:id="@+id/burger"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:text="☰"
            android:textSize="25sp"
            android:textColor="#FFD700"
            android:layout_margin="20sp"
            android:gravity="center_vertical|start"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- App title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:gravity="center_vertical"
            android:text="AutoMekaniko"
            android:textColor="#FFD700"
            android:textSize="20sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/burger"/>

        <!-- Model selector spinner -->
        <Spinner
            android:id="@+id/modelSpinner"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/spinner_border"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/title"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 3D SCENE VIEW -->
    <io.github.sceneview.SceneView
        android:id="@+id/sceneView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- BOTTOM BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#1a1a1a"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFD700"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- SPEED -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/speedcon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/rpmcon">

            <TextView
                android:id="@+id/speedVal"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="—"
                android:textColor="#ffffff"
                android:gravity="center"
                android:textSize="28sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/speed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/speed"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="SPEED"
                android:textColor="#FFD700"
                android:gravity="center"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/speedVal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- RPM -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/rpmcon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintStart_toEndOf="@id/speedcon"
            app:layout_constraintEnd_toStartOf="@id/coolantcon">

            <TextView
                android:id="@+id/rpmVal"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="—"
                android:textColor="#ffffff"
                android:gravity="center"
                android:textSize="28sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/rpm"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/rpm"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="RPM"
                android:textColor="#FFD700"
                android:gravity="center"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/rpmVal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- COOLANT -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/coolantcon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintStart_toEndOf="@id/rpmcon"
            app:layout_constraintEnd_toStartOf="@id/throttlecon">

            <TextView
                android:id="@+id/coolantVal"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="—"
                android:textColor="#ffffff"
                android:gravity="center"
                android:textSize="28sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/coolant"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/coolant"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="COOLANT °C"
                android:textColor="#FFD700"
                android:gravity="center"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/coolantVal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- THROTTLE -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/throttlecon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintStart_toEndOf="@id/coolantcon"
            app:layout_constraintEnd_toStartOf="@id/loadcon">

            <TextView
                android:id="@+id/throttleVal"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="—"
                android:textColor="#ffffff"
                android:gravity="center"
                android:textSize="28sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/throttle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/throttle"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="THROTTLE %"
                android:textColor="#FFD700"
                android:gravity="center"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/throttleVal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- LOAD -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/loadcon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintStart_toEndOf="@id/throttlecon"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/loadVal"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="—"
                android:textColor="#ffffff"
                android:gravity="center"
                android:textSize="28sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/load"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/load"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="LOAD %"
                android:textColor="#FFD700"
                android:gravity="center"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/loadVal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>