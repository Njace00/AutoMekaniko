<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0a">

    <!-- TOP BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#232222"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/burger"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_margin="20sp"
            android:gravity="center_vertical|start"
            android:text="☰"
            android:textColor="#FFD700"
            android:textSize="25sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:gravity="center_vertical"
            android:text="AutoMekaniko"
            android:textColor="#FFD700"
            android:textSize="20sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/burger"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <Spinner
        android:id="@+id/modelSpinner"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_margin="12dp"
        android:background="@drawable/spinner_border"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 3D Scene -->
    <io.github.sceneview.SceneView
        android:id="@+id/sceneView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/modelSpinner"
        app:layout_constraintBottom_toTopOf="@id/slidePanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Lock overlay (blocks touches while locked) -->
    <View
        android:id="@+id/lockOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="true"
        android:focusable="true"
        android:background="@android:color/transparent"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="@id/sceneView"
        app:layout_constraintBottom_toBottomOf="@id/sceneView"
        app:layout_constraintStart_toStartOf="@id/sceneView"
        app:layout_constraintEnd_toEndOf="@id/sceneView"/>

    <!-- Slide panel -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/slidePanel"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:background="#AA111111"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="86dp"
            android:layout_height="38dp"
            android:text="Prev"
            android:textAllCaps="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="86dp"
            android:layout_height="38dp"
            android:text="Next"
            android:textAllCaps="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <Button
            android:id="@+id/btnCameraLock"
            android:layout_width="120dp"
            android:layout_height="34dp"
            android:text="Camera: LOCK"
            android:textAllCaps="false"
            android:textSize="11sp"
            app:layout_constraintTop_toBottomOf="@id/btnNext"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/slideTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Slide 1"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnPrev"
            app:layout_constraintEnd_toStartOf="@id/btnNext"/>

        <TextView
            android:id="@+id/slideDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:maxLines="2"
            app:layout_constraintTop_toBottomOf="@id/slideTitle"
            app:layout_constraintStart_toStartOf="@id/slideTitle"
            app:layout_constraintEnd_toEndOf="@id/slideTitle"/>

        <TextView
            android:id="@+id/tvCameraInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#C8FFD700"
            android:textSize="11sp"
            android:maxLines="2"
            app:layout_constraintTop_toBottomOf="@id/slideDesc"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnCameraLock"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom bar (same as yours) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#1a1a1a"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFD700"
            app:layout_constraintTop_toTopOf="parent"/>
        <!-- SPEED -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/speedcon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/rpmcon">
            <TextView
                android:id="@+id/speedVal"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="—"
                android:textColor="#ffffff"
                android:gravity="center"
                android:textSize="28sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/speed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
            <TextView
                android:id="@+id/speed"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="SPEED"
                android:textColor="#FFD700"
                android:gravity="center"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/speedVal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <!-- RPM -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/rpmcon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintStart_toEndOf="@id/speedcon"
            app:layout_constraintEnd_toStartOf="@id/coolantcon">
            <TextView
                android:id="@+id/rpmVal"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="—"
                android:textColor="#ffffff"
                android:gravity="center"
                android:textSize="28sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/rpm"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
            <TextView
                android:id="@+id/rpm"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="RPM"
                android:textColor="#FFD700"
                android:gravity="center"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/rpmVal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <!-- COOLANT -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/coolantcon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintStart_toEndOf="@id/rpmcon"
            app:layout_constraintEnd_toStartOf="@id/throttlecon">
            <TextView
                android:id="@+id/coolantVal"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="—"
                android:textColor="#ffffff"
                android:gravity="center"
                android:textSize="28sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/coolant"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
            <TextView
                android:id="@+id/coolant"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="COOLANT °C"
                android:textColor="#FFD700"
                android:gravity="center"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/coolantVal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <!-- THROTTLE -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/throttlecon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintStart_toEndOf="@id/coolantcon"
            app:layout_constraintEnd_toStartOf="@id/loadcon">
            <TextView
                android:id="@+id/throttleVal"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="—"
                android:textColor="#ffffff"
                android:gravity="center"
                android:textSize="28sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/throttle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
            <TextView
                android:id="@+id/throttle"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="THROTTLE %"
                android:textColor="#FFD700"
                android:gravity="center"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/throttleVal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <!-- LOAD -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/loadcon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintStart_toEndOf="@id/throttlecon"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView
                android:id="@+id/loadVal"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="—"
                android:textColor="#ffffff"
                android:gravity="center"
                android:textSize="28sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/load"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
            <TextView
                android:id="@+id/load"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="LOAD %"
                android:textColor="#FFD700"
                android:gravity="center"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/loadVal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>


